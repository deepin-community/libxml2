<parameternamelist>
<parametername>doc</parametername>
</parameternamelist>
<parameterdescription>
<para>the document containing the node </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>node</parametername>
</parameternamelist>
<parameterdescription>
<para>the node pointer itself </para>
</parameterdescription>
</parameteritem>
</parameterlist>
<simplesect kind="return"><para>the xlinkType of the node (XLINK_TYPE_NONE if there is no link detected. </para>
</simplesect>
</para>
